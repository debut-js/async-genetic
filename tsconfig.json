{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "outDir": "./lib",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "skipLibCheck": true,
        "strict": false,
        "lib": ["ESNext"],
        "types": ["node", "vite/client"]
    },
    "include": ["src/**/*.ts", "test/**/*.ts", "vite.config.ts"],
    "exclude": ["node_modules", "lib"]
}
